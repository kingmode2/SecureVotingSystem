pipeline {
  agent any
  stages {
    stage('Checkout') { steps { git url: 'https://your-repo-url.git' } }
    stage('Build Frontend') { steps { sh 'cd frontend && npm ci && npm run build' } }
    stage('Build Backend') { steps { sh 'cd backend/SecureVotingSystem && dotnet restore && dotnet build -c Release' } }
    stage('Run Tests') { steps { echo 'No tests configured' } }
    stage('Build Docker') { steps { sh 'docker compose -f docker/docker-compose.yml build' } }
    stage('Deploy') { steps { sh 'docker compose -f docker/docker-compose.yml up -d' } }
  }
}
